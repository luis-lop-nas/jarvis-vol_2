# ============================================================
# JARVIS — variables de entorno
# Copia este archivo como `.env` y rellena los valores reales.
# ============================================================

# --- Ollama (modelos locales) ---
# Host donde corre Ollama. Por defecto el servicio nativo de macOS.
OLLAMA_HOST=http://localhost:11434
# Modelo por defecto para inferencia local.
OLLAMA_DEFAULT_MODEL=llama3.2
# Modelo de embeddings local.
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Kimi (Moonshot AI) ---
KIMI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_DEFAULT_MODEL=moonshot-v1-128k

# --- DeepSeek ---
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# --- OpenRouter (fallback genérico) ---
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Puertos de servicios ---
API_PORT=8080
WEBSOCKET_PORT=8081
CHROMADB_PORT=8000
N8N_PORT=5678

# --- Rutas de almacenamiento ---
CHROMADB_PATH=./data/chromadb
VAULT_PATH=./data/vault
AUDIT_LOG_PATH=./data/audit.log

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# --- Seguridad ---
# Pedir confirmación antes de acciones destructivas (borrar, sobrescribir, etc.).
CONFIRMACION_DESTRUCTIVA=true
# Número máximo de acciones encadenadas sin intervención humana.
MAX_ACCIONES_AUTONOMAS=10
# Activar sandbox de ejecución para comandos de shell y scripts.
SANDBOX_ENABLED=true

# --- Identidad ---
USUARIO_NOMBRE=Luichi
ZONA_HORARIA=Europe/Madrid
