# ============================================================
# JARVIS — variables de entorno
# Copia este archivo como `.env` y rellena los valores reales.
# ============================================================

# --- Kimi API ---
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL_DEFAULT=kimi-k2.6
KIMI_MODEL_THINKING=kimi-k2-thinking

# --- DeepSeek API ---
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL_DEFAULT=deepseek-chat
DEEPSEEK_MODEL_REASONER=deepseek-reasoner

# --- OpenRouter ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Ollama (local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_DEFAULT=gemma4:4b
OLLAMA_MODEL_CODE=qwen3-coder:8b
OLLAMA_MODEL_REASONING=qwen3:8b
OLLAMA_MODEL_EMBED=nomic-embed-text
OLLAMA_MAX_RAM_GB=5.0
OLLAMA_TIMEOUT_S=30

# --- Router ---
ROUTER_PREFER_LOCAL=false
ROUTER_LOG_DECISIONS=true
ROUTER_FALLBACK_ENABLED=true

# --- Puertos de servicios ---
API_PORT=8080
WEBSOCKET_PORT=8081
CHROMADB_PORT=8000
N8N_PORT=5678

# --- Rutas de almacenamiento ---
CHROMADB_PATH=./data/chromadb
VAULT_PATH=./data/vault
AUDIT_LOG_PATH=./data/audit.log
EMBED_CACHE_PATH=./data/embeddings_cache.sqlite

# --- Logging ---
LOG_LEVEL=INFO

# --- Seguridad ---
CONFIRMACION_DESTRUCTIVA=true
MAX_ACCIONES_AUTONOMAS=10
SANDBOX_ENABLED=true

# --- Identidad ---
USUARIO_NOMBRE=Luichi
ZONA_HORARIA=Europe/Madrid

# --- Sesiones ---
# TTL de sesiones persistidas en disco (horas). Default: 24.
SESSION_TTL_HOURS=24

# --- Distribución overlay SwiftUI ---
# Necesario solo para distribuir el overlay fuera del equipo de desarrollo.
# Formato: "Developer ID Application: Tu Nombre (XXXXXXXXXX)"
# Si está vacío: build sin firma (solo para desarrollo local).
# Obtén tu Team ID en: https://developer.apple.com/account
APPLE_DEVELOPER_ID=
# Nombre del perfil de notarytool (configurado con xcrun notarytool store-credentials)
APPLE_NOTARY_PROFILE=jarvis-notary
# Bundle ID de la app (debe coincidir con Info.plist)
APPLE_BUNDLE_ID=com.jarvis.overlay
